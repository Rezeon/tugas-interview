        <mxCell id="OUnJxYAgNCQNu5OT4SBR-13" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="FastAPI (Backend)" vertex="1">
